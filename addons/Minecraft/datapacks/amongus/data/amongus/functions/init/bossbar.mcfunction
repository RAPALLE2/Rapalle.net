
### add bossbar
bossbar add amongus:lobby_display {"text":"Among Us - Waiting For Players!"}
bossbar add amongus:total_tasks {"text":"Total Tasks Completed"}
bossbar add amongus:meltdown {"text":"Reactor Meltdown"}
bossbar add amongus:depleted {"text":"Oxygen Depleted"}

### color bossbar
bossbar set amongus:meltdown color red
bossbar set amongus:depleted color red

### style bossbar
bossbar set amongus:meltdown style notched_10
bossbar set amongus:depleted style notched_10

### max bossbar
bossbar set amongus:meltdown max 30
bossbar set amongus:depleted max 30
